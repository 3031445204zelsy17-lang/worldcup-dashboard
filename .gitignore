# === 环境变量（API key，绝不提交！最高优先级）===
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node
node_modules/
dist/
.vite/

# 数据（原始/处理数据太大，不进仓库）
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# 数据库
*.db
*.sqlite
*.sqlite3

# 系统 / 编辑器
.DS_Store
.vscode/
.idea/

# 日志
*.log
