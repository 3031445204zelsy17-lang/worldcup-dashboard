# === API Keys（自部署时填你自己的；公开站用部署平台的环境变量）===
# 复制本文件为 .env 后填入，.env 不会进 git

# API-Football (api-football.com 官方直连, header 用 x-apisports-key) — 主力数据源(赛程/比分/事件/阵容)
# 注: 免费档仅 2022-2024 赛季; 2026 WC 需 Pro($19/月). Phase 1 先用免费 martj42, 升级时填本 key.
API_FOOTBALL_KEY=

# football-data.org — 备用比分源（免费层够基础）
FOOTBALL_DATA_KEY=

# OpenWeatherMap — 比赛地天气
OPENWEATHER_KEY=

# 飞书推送（可选，B 阶段晨起回看异常推送用）
FEISHU_WEBHOOK=

# === P1-4 FastAPI 只读 API（worker 后台写 DB，API 进程只读，两进程共享同一 SQLite）===
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_DB=data/wc.db
