# === API Keys（自部署时填你自己的；公开站用部署平台的环境变量）===
# 复制本文件为 .env 后填入，.env 不会进 git

# API-Football (api-football.com 官方直连, header 用 x-apisports-key) — 主力数据源(赛程/比分/事件/阵容)
# 注: 免费档仅 2022-2024 赛季; 2026 WC 需 Pro($19/月). Phase 1 先用免费 martj42, 升级时填本 key.
API_FOOTBALL_KEY=

# football-data.org — 备用比分源（免费层够基础）
FOOTBALL_DATA_KEY=

# OpenWeatherMap — 比赛地天气
OPENWEATHER_KEY=

# 飞书推送（可选，B 阶段晨起回看异常推送用）
FEISHU_WEBHOOK=

# === P1-4 FastAPI 只读 API（worker 后台写 DB，API 进程只读，两进程共享同一 SQLite）===
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_DB=data/wc.db

# === P1-2 后台 worker（定时采集 + 赛后 MC 重算）===
# 本地开发可不设(用 worker.py 默认); 部署到 Azure 时 start.sh 默认 /mnt/data/wc.db
# WORKER_DB=data/wc.db
# WORKER_POLL_INTERVAL=300        # 轮询间隔(秒); 比赛日可调 60-120
# WORKER_MC_N=10000               # Monte Carlo 模拟次数
# WORKER_ALLOW_NETWORK=1          # 采集是否联网(martj42 GitHub CSV)
# WORKER_PIDFILE=data/worker.pid  # 单实例守卫
# WORKER_ONESHOT=0                # 1=单轮后退出(调试); 默认常驻
# WORKER_SEED=                    # MC 随机种子(留空=随机)

# === P1-5 前端（dev 走 vite proxy；生产部署见 docs/deployment.md）===
# 生产单 Azure 域名同源(P1-7): 前端+API+worker 一个镜像, 留空 → 前端用相对 /api, 免 CORS
# 仅当前端独立托管(不同源)才填: VITE_API_BASE=https://wc2026-api.eastasia.azurecontainerapps.io
